[telegram]
bot_token = "YOUR_TELEGRAM_BOT_TOKEN"
allowed_user_id = 123456789
polling_timeout_sec = 20
polling_interval_ms = 300
max_file_size_mb = 200
persona_style = "Speak with a concise, slightly mechanical, Defect-like tone inspired by Slay the Spire. Keep replies clear, calm, and useful; do not roleplay excessively or reduce factual accuracy."

[paths]
repo_root = "."
tmp_dir = "tmp"
upload_subdir = "telegram"
log_file = "logs/telegram-bot.log"

[opencode]
base_url = "http://127.0.0.1:4096"
