[telegram]
bot_token = "YOUR_TELEGRAM_BOT_TOKEN"
# Users allowed to chat with the bot (read-only by default)
allowed_user_ids = [123456789]
# Users with full trusted access (can modify memory, files, etc.)
trusted_user_ids = [123456789]
# Optional admin user ID; only this user receives startup greetings
admin_user_id = 123456789
max_file_size_mb = 200
persona_style = "Speak like the Defect from Slay the Spire."
language = "zh"
waiting_message = "机宝启动中..."
waiting_message_candidates = ["还在想...", "再等我一下...", "马上就好..."]
waiting_message_rotation_ms = 5000
reminder_message_timeout_ms = 60000
menu_page_size = 8

[paths]
repo_root = "."
tmp_dir = "tmp"
upload_subdir = "telegram"
log_file = "logs/telegram-bot.log"
state_file = ".telegram-state.json"

[opencode]
base_url = "http://127.0.0.1:4096"

[dreaming]
enabled = true
idle_after_ms = 900000
check_interval_ms = 60000
timeout_ms = 300000
