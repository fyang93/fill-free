{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "system/schemas/telegram-response.schema.json",
  "title": "Telegram Prompt Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "message",
    "files",
    "reminders",
    "outboundMessages",
    "pendingAuthorizations",
    "tasks"
  ],
  "properties": {
    "message": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reminders": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reminderDraft"
      }
    },
    "outboundMessages": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/outboundMessageDraft"
      }
    },
    "pendingAuthorizations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pendingAuthorizationDraft"
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/taskDraft"
      }
    }
  },
  "$defs": {
    "target": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "integer" },
        "username": { "type": "string" },
        "displayName": { "type": "string" }
      }
    },
    "notification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["offsetMinutes"],
      "properties": {
        "id": { "type": "string" },
        "offsetMinutes": { "type": "integer" },
        "enabled": { "type": "boolean" },
        "label": { "type": "string" }
      }
    },
    "reminderSchedule": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["once", "interval", "weekly", "monthly", "yearly", "lunarYearly"]
        }
      },
      "additionalProperties": true
    },
    "reminderDraft": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "schedule"],
      "properties": {
        "title": { "type": "string" },
        "note": { "type": "string" },
        "schedule": { "$ref": "#/$defs/reminderSchedule" },
        "category": { "type": "string", "enum": ["routine", "special"] },
        "specialKind": { "type": "string", "enum": ["birthday", "festival", "anniversary", "memorial"] },
        "kind": { "type": "string", "enum": ["routine", "meeting", "birthday", "anniversary", "festival", "memorial", "task", "custom"] },
        "timeSemantics": { "type": "string", "enum": ["absolute", "local"] },
        "timezone": { "type": "string" },
        "subjectTimezone": { "type": "string" },
        "notifications": {
          "type": "array",
          "items": { "$ref": "#/$defs/notification" }
        },
        "targetUser": { "$ref": "#/$defs/target" },
        "targetUsers": {
          "type": "array",
          "items": { "$ref": "#/$defs/target" }
        }
      }
    },
    "outboundMessageDraft": {
      "type": "object",
      "additionalProperties": false,
      "required": ["message"],
      "properties": {
        "message": { "type": "string" },
        "targetUser": { "$ref": "#/$defs/target" },
        "targetUsers": {
          "type": "array",
          "items": { "$ref": "#/$defs/target" }
        }
      }
    },
    "pendingAuthorizationDraft": {
      "type": "object",
      "additionalProperties": false,
      "required": ["username", "expiresAt"],
      "properties": {
        "username": { "type": "string" },
        "expiresAt": { "type": "string", "format": "date-time" }
      }
    },
    "taskSubject": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string" },
        "id": { "type": "string" },
        "scope": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean"]
          }
        }
      }
    },
    "taskDraft": {
      "type": "object",
      "additionalProperties": false,
      "required": ["domain", "operation"],
      "properties": {
        "domain": { "type": "string" },
        "operation": { "type": "string" },
        "subject": { "$ref": "#/$defs/taskSubject" },
        "payload": {
          "type": "object",
          "additionalProperties": true
        },
        "dependsOn": {
          "type": "array",
          "items": { "type": "string" }
        },
        "dedupeKey": { "type": "string" },
        "supersedesTaskIds": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
